def Scope "materials" (
    cortex_autoMaterials = true
)
{
    def Material "redMat"
    {

        token outputs:surface.connect = </materials/redMat/surface.outputs:surface>

        def Shader "surface"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (1.0, 0.0, 0.0)
            token outputs:surface
        }
    }

    def Material "greenMat"
    {

        token outputs:surface.connect = </materials/greenMat/surface.outputs:surface>

        def Shader "surface"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.0, 1.0, 0.0)
            token outputs:surface
        }
    }

    def Material "blueMat"
    {

        token outputs:surface.connect = </materials/blueMat/surface.outputs:surface>

        def Shader "surface"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.0, 0.0, 1.0)
            token outputs:surface
        }
    }
}
